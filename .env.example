# Copy to .env.local (gitignored) and fill in.
# .env.local is sourced by scripts/sprint1_day1.sh and by uv run.

# Google Cloud
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Elastic Cloud Serverless — TWO endpoints, both needed.
# ELASTIC_ENDPOINT is the Elasticsearch URL (data API), e.g.
#   https://my-cluster.es.us-central1.gcp.elastic.cloud
ELASTIC_ENDPOINT=
# KIBANA_ENDPOINT serves Agent Builder MCP (/api/agent_builder/*). On Serverless
# it's the same project, .kb. instead of .es. — if unset, agent/config.py derives it.
#   https://my-cluster.kb.us-central1.gcp.elastic.cloud
KIBANA_ENDPOINT=
# ELASTIC_API_KEY is the base64-encoded API key from Kibana → Stack Management → API keys
# (or the auto-generated project key shown once on the Serverless connection screen).
# Needs at least: read on indices, write on reunification_cases, and Agent Builder access.
ELASTIC_API_KEY=

# Vertex AI / Gemini — google-genai must be routed via Vertex (uses ADC), not the
# Gemini API (which would need GOOGLE_API_KEY). Run `gcloud auth application-default
# login` once before first use.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Use a Vertex-available model id. gemini-2.0-flash-exp is Gemini-API-only and 404s on Vertex.
GEMINI_MODEL=gemini-2.5-flash

# Twilio (optional — voice gateway + real SMS dispatch). When all three are
# set, dispatch_notification sends real SMS via Twilio's REST API instead of
# falling back to the mock-banner path. Provision a phone number at
# https://console.twilio.com/ and point its Voice webhook to /voice/incoming.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
