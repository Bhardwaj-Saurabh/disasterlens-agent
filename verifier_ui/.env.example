# Verifier UI build-time env. Copy to verifier_ui/.env.local and fill in.
# Vite inlines VITE_-prefixed vars at build time; restart the dev server / rebuild after changes.

# Mapbox public token (pk.*) — when set, the reunification map uses Mapbox raster tiles.
# When absent, the map falls back to OpenStreetMap tiles (zero-config but visually plainer).
# Provision at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=
